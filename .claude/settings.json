{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.mjs\"",
            "timeout": 15,
            "statusMessage": "세션 컨텍스트 주입(최신 handoff + 다음 후보)"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/protect-paths.mjs\"",
            "timeout": 15,
            "statusMessage": "보호 경로 점검(.env/ADR/migrations)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/format-edited.mjs\"",
            "timeout": 70,
            "statusMessage": "편집 파일 자동 포맷/린트(eslint --fix)"
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/docker-rebuild-sensor.mjs\"",
            "timeout": 15,
            "statusMessage": "도커 재빌드 트리거 감지(deps/Dockerfile/compose/.env)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/verify-done-tasks.mjs\"",
            "timeout": 15,
            "statusMessage": "done 태스크 검증 점검"
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/docker-rebuild-stop.mjs\"",
            "timeout": 15,
            "statusMessage": "도커 재빌드 펜딩 점검(AUTO_DOCKER_REBUILD)"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/precompact-note.mjs\"",
            "timeout": 15,
            "statusMessage": "compaction 전 작업 상태 스냅샷"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/tdd-reminder.mjs\"",
            "timeout": 15
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-ready.mjs\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
