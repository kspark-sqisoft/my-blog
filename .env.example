# docker compose 환경 변수 예시. 복사해서 .env 로 사용한다.
# PostgreSQL
POSTGRES_USER=blog
POSTGRES_PASSWORD=blog
POSTGRES_DB=blog

# 운영자 계정 부트스트랩 (시드 스크립트용 — ADR-0002)
OPERATOR_EMAIL=owner@example.com
OPERATOR_PASSWORD=change-me

# JWT 서명 시크릿 (운영에서는 반드시 교체)
JWT_SECRET=change-me-in-production

# 미디어 업로드 (ADR-0012 / ADR-0020). 저장 경로 / 공개 URL 베이스 / 최대 크기(bytes)
# 이미지 5MB / 비디오 50MB — MIME 별로 분리 한도 적용
UPLOAD_DIR=./uploads
UPLOAD_URL_BASE=/uploads
UPLOAD_MAX_BYTES=5242880
UPLOAD_MAX_BYTES_VIDEO=52428800

# seo-feed (ADR-0026). 피드·사이트맵·OG 메타의 절대 URL 기준 + 피드 항목 상한.
# prod 는 반드시 실제 도메인으로 교체한다(예: https://blog.example.com). dev 미설정 시 localhost:5173.
SITE_URL=http://localhost:5173
FEED_MAX_ITEMS=20

# ── Playwright E2E 격리 스택 (T-INFRA-005) ─────────────────────────────────
# docker-compose.e2e.yml + scripts/e2e-isolated.sh 가 사용. 미지정 시 아래 기본값.
# dev 스택(5433/3001/5173)과 절대 겹치지 않도록 5434/3002/5174 를 사용한다.
E2E_DB_PORT=5434
E2E_API_PORT=3002
E2E_WEB_PORT=5174
E2E_POSTGRES_USER=blog
E2E_POSTGRES_PASSWORD=blog
E2E_POSTGRES_DB=blog_e2e
E2E_JWT_SECRET=e2e-jwt-secret-not-for-production
# Playwright 가 접근할 베이스 URL — web 컨테이너 호스트 매핑과 일치해야 한다.
E2E_BASE_URL=http://127.0.0.1:5174
# 격리 시드용 운영자 계정(dev 의 OPERATOR_* 와 독립)
E2E_OPERATOR_EMAIL=owner@example.com
E2E_OPERATOR_PASSWORD=change-me
# E2E_KEEP_STACK=1 → 종료 시 down -v 생략(디버깅용)
# E2E_COMPOSE_PROJECT=my-blog-e2e (기본값, 충돌 회피 시에만 변경)
