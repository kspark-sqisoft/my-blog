// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// 발행 상태 (ADR-0005)
enum PostStatus {
  DRAFT
  PUBLISHED
}

// 사용자 역할 (ADR-0018). ADMIN=슈퍼관리자, AUTHOR=본인 글 작성, MEMBER=로그인 독자
enum UserRole {
  ADMIN
  AUTHOR
  MEMBER
}

// 사용자 (Auth Context)
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String // 작성자 표시 이름 (ADR-0017). 공개 응답엔 email 대신 이 값을 노출
  role         UserRole @default(MEMBER) // 권한 (ADR-0018). 가입 기본 MEMBER, 운영자는 ADMIN
  createdAt    DateTime @default(now())

  posts    Post[]
  comments Comment[] // 로그인 회원이 작성한 댓글 (ADR-0018)

  @@map("users")
}

// 게시글 (Publishing Context, Aggregate Root)
model Post {
  id              String     @id @default(cuid())
  title           String
  contentMarkdown String     // @deprecated T-INFRA-303 마이그레이션 후 후속 ADR 에서 drop (ADR-0021)
  contentHtml     String     @default("") // 본문 HTML(sanitize 통과). ADR-0021. T-INFRA-303 가 채움
  status          PostStatus @default(DRAFT)
  publishedAt     DateTime?
  authorId        String
  author          User       @relation(fields: [authorId], references: [id])
  postTags        PostTag[]
  comments        Comment[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status, publishedAt])
  @@map("posts")
}

// 태그 (Publishing Context, Value Object — ADR-0006)
model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  postTags PostTag[]

  @@map("tags")
}

// Post ↔ Tag 다대다 조인 (ADR-0006)
model PostTag {
  postId String
  tagId  String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

// 댓글 (Conversation Context, Aggregate Root)
model Comment {
  id          String    @id @default(cuid())
  postId      String
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId    String? // 답글 관계 (깊이 2까지 — 서비스 계층에서 강제, ADR-0013)
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[] @relation("CommentReplies")
  userId      String? // 로그인 회원 작성자 (ADR-0018). 비로그인은 null + displayName
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  displayName String? // 익명 독자 표시 이름(선택)
  body        String
  createdAt   DateTime  @default(now())

  @@index([postId])
  @@index([userId])
  @@map("comments")
}
