{
  "$schema": "https://unpkg.com/jscpd@4/schema.json",
  "threshold": 5,
  "minTokens": 60,
  "format": ["typescript", "tsx"],
  "reporters": ["console"],
  "gitignore": true,
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "packages/api/prisma/migrations/**"
  ]
}
